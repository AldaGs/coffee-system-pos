{
  "rewrites": [
    {
      "source": "/api/add-domain",
      "destination": "/api/domains?op=add"
    },
    {
      "source": "/api/remove-domain",
      "destination": "/api/domains?op=remove"
    },
    {
      "source": "/api/resolve-domain",
      "destination": "/api/domains"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "header",
          "key": "accept",
          "value": "(?!.*text/event-stream).*"
        }
      ],
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/manifest.webmanifest",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/manifest+json"
        }
      ]
    }
  ]
}